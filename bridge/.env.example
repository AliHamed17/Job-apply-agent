# ── Job Agent connection ──────────────────────────────────────────────────────
# URL of your running job-agent API (no trailing slash)
JOB_AGENT_URL=http://localhost:8000

# Must match SECRET_KEY in your main .env
JOB_AGENT_TOKEN=change-me

# ── Group filtering ───────────────────────────────────────────────────────────
# "true"  = watch every group you are in
# "false" = only watch groups whose name matches GROUP_KEYWORDS
WATCH_ALL_GROUPS=false

# Comma-separated keywords (case-insensitive).
# Only used when WATCH_ALL_GROUPS=false.
GROUP_KEYWORDS=jobs,hiring,careers,work,tech,remote,vacancy,recruitment,opportunities

# ── URL filtering ─────────────────────────────────────────────────────────────
# "true"  = only forward known job-board URLs (recommended)
# "false" = forward every URL found in watched groups
JOB_URL_ONLY=true

# ── Session & logging ─────────────────────────────────────────────────────────
# Where to save the WhatsApp session (relative to bridge/)
SESSION_DIR=./.wwebjs_auth

# info | verbose | silent
LOG_LEVEL=info
