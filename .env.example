# ─── WhatsApp Cloud API ───────────────────────────────
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_API_TOKEN=your-whatsapp-api-bearer-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_APP_SECRET=your-app-secret-for-signature-verification

# ─── Database ─────────────────────────────────────────
DATABASE_URL=sqlite:///./job_agent.db

# ─── Redis (Celery broker) ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── LLM Provider ────────────────────────────────────
# Options: "openai" or "anthropic"
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=gpt-4o

# ─── Application Modes ───────────────────────────────
DRAFT_ONLY=true
AUTO_APPLY=false

# ─── Rate Limiting ───────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=10
POLITE_CRAWL_DELAY_SECONDS=2.0

# ─── CORS ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Environment ─────────────────────────────────────
APP_ENV=dev

# ─── Security ────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret

# ─── Allowed Senders (comma-separated phone numbers) ─
ALLOWED_SENDERS=

# ─── User Profile Path ──────────────────────────────
USER_PROFILE_PATH=user_profile.yaml
